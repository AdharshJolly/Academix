# ==========================================
# CampusFlow Backend Environment Configuration
# ==========================================

# --- Core Server ---
ENVIRONMENT=development
SECRET_KEY=your_secure_random_string_here
API_V1_PREFIX=/api/v1

# --- Database & Auth (Supabase) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- AI Intelligence (Groq) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
PRIMARY_MODEL=moonshotai/kimi-k2-instruct
FALLBACK_MODEL=llama-3.3-70b-versatile

# --- Google Calendar API (OAuth2) ---
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- Make.com Automation (WhatsApp & Logging) ---
# The URL of your active Make.com webhook trigger
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/your_webhook_id_here
# The secret token Make.com must send back to authorize logs
AUTOMATION_CALLBACK_SECRET=your_secure_callback_secret_here

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
